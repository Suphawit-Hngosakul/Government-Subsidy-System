            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"โครงการคนละครึ่ง เฟส 5\",\n  \"description\": \"โครงการช่วยเหลือค่าครองชีพสำหรับประชาชนทั่วไปโดยรัฐบาลอุดหนุน 50%\",\n  \"active\": true,\n  \"criteria\": {\n    \"minAge\": 18,\n    \"maxAge\": 60,\n    \"maxMonthlyIncome\": 30000,\n    \"maxDepositTotal\": 500000,\n    \"allowedSsoSections\": [\"40\", \"39\"],\n    \"requirePromptPay\": true,\n    \"requireSso\": true,\n    \"requireKtb\": true\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/admin/project",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "admin",
                "project"
              ]
            },

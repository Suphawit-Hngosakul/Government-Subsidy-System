{
  "info": {
    "_postman_id": "8bb3858c-68ff-4a4a-b5e0-d096b7582ea5",
    "name": "Government Subsidy System E2E Collection",
    "description": "ชุดการทดสอบ API ครอบคลุมทุกระบบย่อยของ Government Subsidy System (eKYC, Auth, Admin, External Providers, Claim Orchestration, Officer Queue) สำหรับการทำ Demo และการทดสอบ Newman อัตโนมัติ",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Authentication & eKYC",
      "description": "โฟลเดอร์ทดสอบระบบการลงทะเบียน ยืนยันตัวตนผ่านบัตรประชาชน (eKYC OCR & Confirm) และการล็อกอินเข้าระบบประชาชน",
      "item": [
        {
          "name": "eKYC OCR",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nationalId\": \"{{national_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/ekyc/ocr",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "ekyc",
                "ocr"
              ]
            },
            "description": "จำลองการอ่านข้อมูลบัตรประชาชนผ่านกล้องหรือระบบภาพ (OCR) เพื่อสแกนดึงข้อมูลตัวตนเบื้องต้น"
          },
          "response": []
        },
        {
          "name": "eKYC Confirm",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nationalId\": \"{{national_id}}\",\n  \"laserCode\": \"{{laser_code}}\",\n  \"fullName\": \"สมชาย ใจดี\",\n  \"dateOfBirth\": \"1991-05-20\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/ekyc/confirm",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "ekyc",
                "confirm"
              ]

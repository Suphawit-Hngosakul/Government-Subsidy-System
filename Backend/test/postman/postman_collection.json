            "description": "ยืนยันผลการเปรียบเทียบใบหน้าและข้อมูล Laser Code หลังบัตรประชาชนเพื่อเปลี่ยนสถานะ KYC เป็น verified"
          },
          "response": []
        },
        {
          "name": "Register Citizen PIN",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nationalId\": \"{{national_id}}\",\n  \"password\": \"{{password}}\",\n  \"phone\": \"{{phone}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "register"
              ]
            },
            "description": "ลงทะเบียนประชาชนและตั้งรหัส PIN เข้าระบบสำหรับการใช้งาน G-Wallet"
          },
          "response": []
        },
        {
          "name": "Login Citizen",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response && response.token) {",
                  "    pm.environment.set(\"citizen_token\", response.token);",
                  "    console.log(\"Saved citizen_token to environment:\", response.token);",
                  "}",
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nationalId\": \"{{national_id}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            },
            "description": "ล็อกอินและดึง Token สำหรับเรียกใช้ API ภายใต้สิทธิ์ของประชาชนท่านนั้น"
          },
          "response": []
        },
        {
          "name": "Logout Citizen",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{citizen_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/logout",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "logout"
              ]
            },
            "description": "ออกจากระบบและทำลาย Session Token"
          },
          "response": []
        }
      ]
    },
